# UPPORTUNIX Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# SERVER
# =============================================================================
PORT=4000
NODE_ENV=development

# =============================================================================
# SECURITY
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=7d

# =============================================================================
# DATABASE
# =============================================================================
DB_PATH=./upportunix.db

# =============================================================================
# ADMIN DEFAULT
# =============================================================================
ADMIN_EMAIL=admin@upportunix-ia.fr
ADMIN_PASSWORD=Admin123!

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGIN=http://localhost:3000,https://upportunix-ia.fr,https://www.upportunix-ia.fr

# =============================================================================
# URLS
# =============================================================================
FRONTEND_URL=https://upportunix-ia.fr
API_URL=https://api.upportunix-ia.fr

# =============================================================================
# AI (ANTHROPIC)
# =============================================================================
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# SMTP (Default system mailer - optional)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@upportunix-ia.fr
SMTP_PASS=your-app-specific-password
EMAIL_FROM=UPPORTUNIX <contact@upportunix-ia.fr>

# =============================================================================
# FILE UPLOADS
# =============================================================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15

# =============================================================================
# STRIPE (Payments)
# =============================================================================
# Uncomment when ready:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# PLANS PRICING (in cents EUR)
# =============================================================================
# Starter: Free
# Pro: 49€/month
# Agency: 99€/month
# Enterprise: 299€/month
